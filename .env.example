# =============================================
# FlowvVibe Environment Variables
# =============================================

# --- Server ---
PORT=3001

# --- Database (Neon DB recommended) ---
# Get your connection string from https://console.neon.tech
# Use the *pooler* URL for better serverless performance
DATABASE_URL=postgresql://neondb_owner:<password>@ep-<name>-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Pool size override (optional — auto-detected for Neon)
# DB_POOL_MAX=5

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-secret

# --- Frontend URL (used for CORS) ---
# Comma-separated list of allowed origins (in addition to localhost)
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

# --- AI / OpenRouter ---
OPENROUTER_API_KEY=

# --- Slack Integration ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- WhatsApp Business API ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# --- Twilio (Voice Calls) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
