{
  "name": "flowvibe",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm install -w frontend && npm run build -w frontend",
    "lint": "npm run lint -w frontend",
    "setup:db": "psql -U postgres -d flowvibe -f backend/setup.sql",
    "deploy": "npm run deploy -w backend"
  }
}