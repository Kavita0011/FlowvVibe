{
  "name": "flowvibe",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "setup:db": "psql -U postgres -d flowvibe -f backend/setup.sql",
    "deploy": "cd backend && npx wrangler deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "buffer": "^6.0.3",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.9"
  }
}
