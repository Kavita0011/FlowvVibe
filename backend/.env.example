# FlowvVibe Backend Environment Variables
PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=flowvibe
DB_PASSWORD=flowvibe2024
DB_NAME=flowvibe
DATABASE_URL=postgresql://flowvibe:flowvibe2024@localhost:5432/flowvibe

# JWT
JWT_SECRET=flowvibe-jwt-secret-2024

# OpenRouter AI (https://openrouter.ai/) — flow generation and chat replies
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: OpenRouter model id for public chat (default: openai/gpt-4o-mini)
CHAT_LLM_MODEL=

# Twilio (for voice calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TWIML_URL=

# SMTP (for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Slack Integration
# Get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret

# WhatsApp Integration  
# Get from: https://developers.facebook.com/apps
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_API_VERSION=v21.0

# Zapier (optional)
ZAPIER_WEBHOOK_URL=