# FlowvVibe Environment Variables
# Note: Sensitive data should be set in Cloudflare Secrets, not here

# === Database (Neon PostgreSQL) ===
# Set via Cloudflare: wrangler secret put NEON_DATABASE_URL
# Or configure Neon connection pooler URL here

# === Admin Credentials ===
# Set via Cloudflare: 
# wrangler secret put VITE_ADMIN_EMAIL
# wrangler secret put VITE_ADMIN_PASSWORD_HASH

# === Payment (Razorpay) ===
# Set via Cloudflare:
# wrangler secret put VITE_RAZORPAY_KEY_ID

# === API URLs ===
VITE_API_URL=https://flowvibe-api.kavita workers.dev
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=