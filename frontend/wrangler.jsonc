{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flowvibe",
  "compatibility_date": "2026-04-14",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist", // This tells Wrangler where the Vite build output is
    "binding": "ASSETS"
    // "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
