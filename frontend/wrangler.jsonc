{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flowvibe-frontend",
  // 1. Remove "main" if you are just deploying a static frontend
  "compatibility_date": "2024-04-01",
  "assets": {
    "directory": "./dist", 
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}