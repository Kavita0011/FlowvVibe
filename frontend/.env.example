# FlowVibe Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL
VITE_API_URL=http://localhost:3001

# Neon PostgreSQL Database Connection
# Get your connection string from Neon Console: https://console.neon.tech
# PostgreSQL connection string (for pg package):
# Format: postgresql://username:password@host/database?sslmode=require
VITE_NEON_DATABASE_URL=postgresql://your-username:your-password@ep-silent-paper-am8ltwpf.apirest.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# NEXT_PUBLIC version for Next.js compatibility
NEXT_PUBLIC_NEON_DATABASE_URL=postgresql://your-username:your-password@ep-silent-paper-am8ltwpf.apirest.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# Note: Get your username and password from Neon Console at https://console.neon.tech
