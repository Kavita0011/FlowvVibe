# FlowVibe Environment Variables
# Copy to .env.local for local development

# === Database (Neon or Supabase) ===
# Neon (Postgres) - for database
VITE_NEON_DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Supabase - for auth only
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# === Payment Gateway (Razorpay) ===
VITE_RAZORPAY_KEY_ID=your_key_id
VITE_RAZORPAY_KEY_SECRET=your_key_secret

# === Admin Bank Details (for invoices) ===
VITE_ADMIN_UPI=yourname@upi
VITE_ADMIN_BANK_NAME=Your Bank Name
VITE_ADMIN_ACCOUNT_NUMBER=XXXXXXXXXXXX
VITE_ADMIN_IFSC=XXXXX000XXX